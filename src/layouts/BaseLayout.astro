---
import Nav from "../components/Nav.astro";

const { title = "3dbok", showNav = true } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style is:global>
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        background: #FAFAF8;
      }
      :root {
        --color-background-primary: #ffffff;
        --color-background-secondary: #F4F3EF;
        --color-background-tertiary: #FAFAF8;
        --color-text-primary: #1A1A18;
        --color-text-secondary: #6B6A66;
        --color-border-tertiary: rgba(0,0,0,0.1);
        --color-border-secondary: rgba(0,0,0,0.18);
        --border-radius-md: 8px;
        --border-radius-lg: 12px;
      }
      input, textarea, button { font-family: inherit; }
      input:focus, textarea:focus, button:focus { outline: 2px solid #1D9E75; outline-offset: 1px; }
    </style>
  </head>
  <body>
    <div style="min-height: 100vh; background: var(--color-background-tertiary);">
      {showNav && <Nav />}
      <slot />
    </div>
  </body>
</html>
