---
import Nav from "../components/Nav.astro";

const { title = "3dbok", showNav = true } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style is:global>
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: Inter, Manrope, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        background: #F8F8FA;
      }
      :root {
        --font-heading: "Space Grotesk", Sora, Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        --font-body: Inter, Manrope, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        --font-logo: Impact, "Arial Black", "Archivo Black", sans-serif;
        --color-brand-primary: #4959B8;
        --color-brand-dark: #2F3A8C;
        --color-brand-soft: #EEF0FF;
        --color-brand-sand: #DBD4A0;
        --color-brand-sand-dark: #C2B86E;
        --color-brand-warm: #F7F4E3;
        --color-background-primary: #ffffff;
        --color-background-secondary: #F7F4E3;
        --color-background-tertiary: #F8F8FA;
        --color-text-primary: #111827;
        --color-text-secondary: #5F6472;
        --color-border-tertiary: rgba(73, 89, 184, 0.14);
        --color-border-secondary: rgba(73, 89, 184, 0.28);
        --shadow-card: 0 14px 36px rgba(17, 24, 39, 0.07);
        --border-radius-sm: 10px;
        --border-radius-md: 14px;
        --border-radius-lg: 20px;
      }
      input, textarea, button { font-family: inherit; }
      h1, h2, h3 {
        font-family: var(--font-heading);
        letter-spacing: 0;
      }
      input:focus, textarea:focus, button:focus { outline: 2px solid var(--color-brand-primary); outline-offset: 2px; }
    </style>
  </head>
  <body>
    <div style="min-height: 100vh; background: var(--color-background-tertiary);">
      {showNav && <Nav />}
      <slot />
    </div>
  </body>
</html>
