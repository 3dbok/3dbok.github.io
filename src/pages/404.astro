---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <main style="max-width: 520px; margin: 0 auto; padding: 4rem 1.5rem; text-align: center;">
    <h1 style="font-size: 24px; font-weight: 500; color: var(--color-text-primary); margin-bottom: 0.75rem;">
      Página no encontrada
    </h1>
    <p style="font-size: 14px; color: var(--color-text-secondary); line-height: 1.6; margin-bottom: 2rem;">
      La página que buscas no existe o ha cambiado de dirección.
    </p>
    <a
      href="/"
      style="background: #1D9E75; color: white; border: none; border-radius: var(--border-radius-md); padding: 12px 28px; font-size: 14px; font-weight: 500; cursor: pointer; text-decoration: none;"
    >
      Volver al inicio
    </a>
  </main>
</BaseLayout>
