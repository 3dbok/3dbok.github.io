---
import BaseLayout from "../layouts/BaseLayout.astro";

const niches = [
  { icon: "🎲", label: "Miniaturas D&D / Warhammer", desc: "Figuras únicas para tus partidas" },
  { icon: "🏠", label: "Decoración del hogar", desc: "Organizadores, jarrones, piezas únicas" },
  { icon: "🐾", label: "Accesorios para mascotas", desc: "Comederos, juguetes personalizados" },
  { icon: "🎭", label: "Cosplay y props", desc: "Accesorios para disfraces y eventos" },
  { icon: "🎁", label: "Regalos personalizados", desc: "Con nombre, fecha, lo que imagines" },
  { icon: "🔧", label: "Piezas y recambios", desc: "Soportes, adaptadores, accesorios" },
];

const steps = [
  {
    n: "1",
    title: "Cuéntanos qué quieres",
    desc: "Describe tu idea. Sube fotos o diseño de referencia si tienes. No necesitas saber nada de impresión 3D.",
  },
  {
    n: "2",
    title: "Se prepara el diseño",
    desc: "En 24–48h recibes un boceto para aprobar antes de que empiece el trabajo de verdad.",
  },
  {
    n: "3",
    title: "Un impresor cercano lo fabrica",
    desc: "Recibes fotos del proceso. Cuando está listo, te lo entregamos.",
  },
];

const testimonials = [
  {
    name: "Laura M.",
    text: "Encargué miniaturas para mi campaña de D&D y quedaron perfectas. El diseñador entendió exactamente lo que quería.",
    item: "Miniaturas personalizadas",
  },
  {
    name: "Carlos R.",
    text: "Necesitaba un soporte específico para mi monitor y no existía en ningún sitio. En una semana lo tenía en casa.",
    item: "Soporte de escritorio",
  },
  {
    name: "Ana P.",
    text: "El regalo más original que he dado. El proceso fue facilísimo, no tuve que entender nada técnico.",
    item: "Regalo personalizado",
  },
];
---

<BaseLayout>
  <main>
    <section style="background: var(--color-background-primary); border-bottom: 0.5px solid var(--color-border-tertiary); padding: 5rem 1.5rem 4rem; text-align: center;">
      <p style="font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-brand-primary); font-weight: 700; margin-bottom: 1rem;">
        Impresión 3D para todos
      </p>
      <h1 style="font-size: clamp(2rem, 5vw, 3.25rem); font-weight: 780; line-height: 1.15; color: var(--color-text-primary); max-width: 700px; margin: 0 auto 1.25rem;">
        Lo que imaginas,<br />impreso en 3D y en tu puerta
      </h1>
      <p style="font-size: 18px; color: var(--color-text-secondary); max-width: 500px; margin: 0 auto 2.5rem; line-height: 1.6;">
        Muéstranos qué quieres. Un diseñador la crea. Un impresor cercano la fabrica.
        Sin tecnicismos, sin complicaciones.
      </p>
      <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
        <a
          href="/briefing"
          style="background: var(--color-brand-primary); color: white; border: none; border-radius: var(--border-radius-md); padding: 14px 32px; font-size: 16px; font-weight: 700; cursor: pointer; text-decoration: none; box-shadow: 0 14px 30px rgba(73, 89, 184, 0.22);"
        >
          Hacer mi pedido →
        </a>
        <a
          href="/seguimiento"
          style="background: var(--color-brand-soft); color: var(--color-brand-primary); border: 1px solid var(--color-border-secondary); border-radius: var(--border-radius-md); padding: 14px 24px; font-size: 16px; font-weight: 650; cursor: pointer; text-decoration: none;"
        >
          Ver seguimiento
        </a>
      </div>

      <div style="display: flex; gap: 2rem; justify-content: center; flex-wrap: wrap; margin-top: 3rem;">
        {[
          ["✓", "Sin conocimientos técnicos"],
          ["✓", "Boceto previo siempre"],
          ["✓", "Impresores verificados"],
        ].map(([icon, text]) => (
          <span style="font-size: 13px; color: var(--color-text-secondary);">
            <span style="color: var(--color-brand-primary); margin-right: 6px;">{icon}</span>{text}
          </span>
        ))}
      </div>
    </section>

    <section style="padding: 4rem 1.5rem; max-width: 860px; margin: 0 auto;">
      <h2 style="font-size: 22px; font-weight: 760; text-align: center; margin-bottom: 3rem; color: var(--color-text-primary);">
        Cómo funciona
      </h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 2rem;">
        {steps.map((step) => (
          <div style="background: var(--color-background-primary); border: 1px solid var(--color-border-tertiary); border-radius: var(--border-radius-lg); padding: 1.5rem; box-shadow: var(--shadow-card);">
            <div style="width: 34px; height: 34px; border-radius: 50%; background: var(--color-brand-soft); display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;">
              <span style="font-size: 13px; font-weight: 760; color: var(--color-brand-dark);">{step.n}</span>
            </div>
            <h3 style="font-size: 15px; font-weight: 720; margin-bottom: 8px; color: var(--color-text-primary);">
              {step.title}
            </h3>
            <p style="font-size: 14px; color: var(--color-text-secondary); line-height: 1.6; margin: 0;">
              {step.desc}
            </p>
          </div>
        ))}
      </div>
    </section>

    <section style="background: var(--color-brand-dark); padding: 3.5rem 1.5rem; text-align: center;">
      <h2 style="font-size: 22px; font-weight: 760; color: white; margin-bottom: 0.75rem;">
        ¿Tienes una impresora 3D?
      </h2>
      <p style="color: rgba(255,255,255,0.7); font-size: 15px; margin-bottom: 1.75rem;">
        Forma parte de la comunidad de 3dbok. Sin inversión, sin compromiso.
      </p>
      <a
        href="/impresor"
        style="background: white; color: var(--color-brand-dark); border: none; border-radius: var(--border-radius-md); padding: 12px 28px; font-size: 15px; font-weight: 700; cursor: pointer; text-decoration: none;"
      >
        Registrarme como impresor →
      </a>
    </section>

    <footer style="background: var(--color-background-primary); border-top: 0.5px solid var(--color-border-tertiary); padding: 2rem 1.5rem; text-align: center;">
      <p style="font-size: 13px; color: var(--color-text-secondary); margin: 0;">
        © 2026 3dbok · Hecho en España 🇪🇸
      </p>
    </footer>
  </main>

  <style>
    .landing-choice-card:hover {
      border-color: var(--color-brand-primary) !important;
      background: var(--color-brand-soft) !important;
    }
  </style>
</BaseLayout>
