---
import BaseLayout from "../layouts/BaseLayout.astro";

const niches = [
  { icon: "🎲", label: "Miniaturas D&D / Warhammer", desc: "Figuras únicas para tus partidas" },
  { icon: "🏠", label: "Decoración del hogar", desc: "Organizadores, jarrones, piezas únicas" },
  { icon: "🐾", label: "Accesorios para mascotas", desc: "Comederos, juguetes personalizados" },
  { icon: "🎭", label: "Cosplay y props", desc: "Accesorios para disfraces y eventos" },
  { icon: "🎁", label: "Regalos personalizados", desc: "Con nombre, fecha, lo que imagines" },
  { icon: "🔧", label: "Piezas y recambios", desc: "Soportes, adaptadores, accesorios" },
];

const steps = [
  {
    n: "1",
    title: "Cuéntanos qué quieres",
    desc: "Describe tu idea con palabras normales. Sube fotos de referencia si tienes. No necesitas saber nada de impresión 3D.",
  },
  {
    n: "2",
    title: "Un diseñador lo prepara",
    desc: "En 24–48h recibes un boceto para aprobar antes de que empiece el trabajo de verdad.",
  },
  {
    n: "3",
    title: "Un impresor cercano lo fabrica",
    desc: "Recibes fotos del proceso. Cuando está listo, te llega a casa.",
  },
];

const testimonials = [
  {
    name: "Laura M.",
    text: "Encargué miniaturas para mi campaña de D&D y quedaron perfectas. El diseñador entendió exactamente lo que quería.",
    item: "Miniaturas personalizadas",
  },
  {
    name: "Carlos R.",
    text: "Necesitaba un soporte específico para mi monitor y no existía en ningún sitio. En una semana lo tenía en casa.",
    item: "Soporte de escritorio",
  },
  {
    name: "Ana P.",
    text: "El regalo más original que he dado. El proceso fue facilísimo, no tuve que entender nada técnico.",
    item: "Regalo personalizado",
  },
];
---

<BaseLayout>
  <main>
    <section style="background: var(--color-background-primary); border-bottom: 0.5px solid var(--color-border-tertiary); padding: 5rem 1.5rem 4rem; text-align: center;">
      <p style="font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: #1D9E75; font-weight: 500; margin-bottom: 1rem;">
        Impresión 3D para todos
      </p>
      <h1 style="font-size: clamp(2rem, 5vw, 3.25rem); font-weight: 500; line-height: 1.15; color: var(--color-text-primary); max-width: 700px; margin: 0 auto 1.25rem;">
        Lo que imaginas,<br />impreso en 3D y en tu puerta
      </h1>
      <p style="font-size: 18px; color: var(--color-text-secondary); max-width: 500px; margin: 0 auto 2.5rem; line-height: 1.6;">
        Describe tu idea. Un diseñador la crea. Un impresor cercano la fabrica.
        Sin tecnicismos, sin complicaciones.
      </p>
      <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
        <a
          href="/briefing"
          style="background: #1D9E75; color: white; border: none; border-radius: var(--border-radius-md); padding: 14px 32px; font-size: 16px; font-weight: 500; cursor: pointer; text-decoration: none;"
        >
          Hacer mi pedido →
        </a>
        <a
          href="/seguimiento"
          style="background: none; color: var(--color-text-secondary); border: 0.5px solid var(--color-border-secondary); border-radius: var(--border-radius-md); padding: 14px 24px; font-size: 16px; cursor: pointer; text-decoration: none;"
        >
          Ver seguimiento
        </a>
      </div>

      <div style="display: flex; gap: 2rem; justify-content: center; flex-wrap: wrap; margin-top: 3rem;">
        {[
          ["✓", "Sin conocimientos técnicos"],
          ["✓", "Boceto previo siempre"],
          ["✓", "Impresores verificados"],
          ["✓", "Garantía de reimpresión"],
        ].map(([icon, text]) => (
          <span style="font-size: 13px; color: var(--color-text-secondary);">
            <span style="color: #1D9E75; margin-right: 6px;">{icon}</span>{text}
          </span>
        ))}
      </div>
    </section>

    <section style="padding: 4rem 1.5rem; max-width: 860px; margin: 0 auto;">
      <h2 style="font-size: 22px; font-weight: 500; text-align: center; margin-bottom: 3rem; color: var(--color-text-primary);">
        Cómo funciona
      </h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 2rem;">
        {steps.map((step) => (
          <div style="background: var(--color-background-primary); border: 0.5px solid var(--color-border-tertiary); border-radius: var(--border-radius-lg); padding: 1.5rem;">
            <div style="width: 32px; height: 32px; border-radius: 50%; background: #E1F5EE; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;">
              <span style="font-size: 13px; font-weight: 500; color: #0F6E56;">{step.n}</span>
            </div>
            <h3 style="font-size: 15px; font-weight: 500; margin-bottom: 8px; color: var(--color-text-primary);">
              {step.title}
            </h3>
            <p style="font-size: 14px; color: var(--color-text-secondary); line-height: 1.6; margin: 0;">
              {step.desc}
            </p>
          </div>
        ))}
      </div>
    </section>

    <section style="background: var(--color-background-primary); border-top: 0.5px solid var(--color-border-tertiary); border-bottom: 0.5px solid var(--color-border-tertiary); padding: 4rem 1.5rem;">
      <div style="max-width: 860px; margin: 0 auto;">
        <h2 style="font-size: 22px; font-weight: 500; text-align: center; margin-bottom: 0.5rem; color: var(--color-text-primary);">
          ¿Qué puedes pedir?
        </h2>
        <p style="text-align: center; color: var(--color-text-secondary); font-size: 15px; margin-bottom: 2.5rem;">
          Si lo puedes imaginar, se puede imprimir.
        </p>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
          {niches.map((n) => (
            <a
              class="landing-choice-card"
              href="/briefing"
              style="border: 0.5px solid var(--color-border-tertiary); border-radius: var(--border-radius-lg); padding: 1.25rem; cursor: pointer; transition: border-color 0.15s; background: var(--color-background-secondary); text-decoration: none;"
            >
              <div style="font-size: 24px; margin-bottom: 8px;">{n.icon}</div>
              <p style="font-weight: 500; font-size: 14px; margin-bottom: 4px; color: var(--color-text-primary);">
                {n.label}
              </p>
              <p style="font-size: 13px; color: var(--color-text-secondary); margin: 0;">
                {n.desc}
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section style="padding: 4rem 1.5rem; max-width: 860px; margin: 0 auto;">
      <h2 style="font-size: 22px; font-weight: 500; text-align: center; margin-bottom: 2.5rem; color: var(--color-text-primary);">
        Lo que dicen nuestros clientes
      </h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem;">
        {testimonials.map((t) => (
          <div style="background: var(--color-background-primary); border: 0.5px solid var(--color-border-tertiary); border-radius: var(--border-radius-lg); padding: 1.25rem;">
            <p style="font-size: 14px; color: var(--color-text-secondary); line-height: 1.7; margin-bottom: 1rem;">
              "{t.text}"
            </p>
            <div style="display: flex; justify-content: space-between; align-items: center;">
              <span style="font-weight: 500; font-size: 13px; color: var(--color-text-primary);">{t.name}</span>
              <span style="font-size: 11px; color: #0F6E56; background: #E1F5EE; padding: 3px 8px; border-radius: var(--border-radius-md);">
                {t.item}
              </span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section style="background: #085041; padding: 3.5rem 1.5rem; text-align: center;">
      <h2 style="font-size: 22px; font-weight: 500; color: white; margin-bottom: 0.75rem;">
        ¿Tienes una impresora 3D?
      </h2>
      <p style="color: rgba(255,255,255,0.7); font-size: 15px; margin-bottom: 1.75rem;">
        Convierte tu equipo en una fuente de ingresos. Sin inversión, sin compromiso.
      </p>
      <a
        href="/impresor"
        style="background: white; color: #085041; border: none; border-radius: var(--border-radius-md); padding: 12px 28px; font-size: 15px; font-weight: 500; cursor: pointer; text-decoration: none;"
      >
        Registrarme como impresor →
      </a>
    </section>

    <footer style="background: var(--color-background-primary); border-top: 0.5px solid var(--color-border-tertiary); padding: 2rem 1.5rem; text-align: center;">
      <p style="font-size: 13px; color: var(--color-text-secondary); margin: 0;">
        © 2025 Fabrica3D · Hecho en España 🇪🇸
      </p>
    </footer>
  </main>

  <style>
    .landing-choice-card:hover {
      border-color: #1D9E75 !important;
    }
  </style>
</BaseLayout>
