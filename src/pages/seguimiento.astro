---
import BaseLayout from "../layouts/BaseLayout.astro";

const DEMO_ORDER = {
  orderId: "F3D-X7K2P",
  category: "Miniatura de dragón negro",
  status: 2,
  designer: { name: "Marta G.", role: "Diseñadora 3D" },
  printer: { name: "Javier R.", role: "Impresor", location: "Málaga (8 km)" },
};

const STAGES = [
  { id: 0, label: "Briefing recibido", desc: "Tu pedido ha sido registrado", icon: "📋" },
  { id: 1, label: "Boceto en revisión", desc: "El diseñador está preparando una propuesta", icon: "✏️" },
  { id: 2, label: "Diseño aprobado", desc: "Has aprobado el boceto final", icon: "✅" },
  { id: 3, label: "En impresión", desc: "Tu pieza se está fabricando", icon: "🖨️" },
  { id: 4, label: "Enviado", desc: "Tu pedido va de camino", icon: "📦" },
];
---

<BaseLayout>
  <main data-search-screen style="max-width: 480px; margin: 0 auto; padding: 4rem 1.5rem;">
    <h1 style="font-size: 22px; font-weight: 500; color: var(--color-text-primary); margin-bottom: 0.5rem;">
      Seguir mi pedido
    </h1>
    <p style="font-size: 14px; color: var(--color-text-secondary); margin-bottom: 2rem;">
      Introduce tu número de pedido. Lo encuentras en el email de confirmación.
    </p>
    <input
      data-order-id
      type="text"
      placeholder="Ej: F3D-X7K2P"
      style="width: 100%; box-sizing: border-box; padding: 12px; font-size: 14px; border-radius: var(--border-radius-md); border: 0.5px solid var(--color-border-secondary); background: var(--color-background-primary); color: var(--color-text-primary); margin-bottom: 1rem; font-family: inherit;"
    />
    <button
      data-search-order
      type="button"
      style="width: 100%; background: var(--color-brand-primary); color: white; border: none; border-radius: var(--border-radius-md); padding: 12px; font-size: 15px; font-weight: 700; cursor: pointer; box-shadow: 0 12px 26px rgba(73, 89, 184, 0.2);"
    >
      Buscar pedido
    </button>
    <p style="font-size: 12px; color: var(--color-text-secondary); margin-top: 1rem; text-align: center;">
      Demo: pulsa "Buscar pedido" para ver un ejemplo de seguimiento
    </p>
  </main>

  <main data-result-screen hidden style="max-width: 560px; margin: 0 auto; padding: 2.5rem 1.5rem 4rem;">
    <button
      data-reset-search
      type="button"
      style="background: none; border: none; cursor: pointer; color: var(--color-text-secondary); font-size: 14px; padding: 0; margin-bottom: 1.5rem;"
    >
      ← Buscar otro pedido
    </button>

    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem;">
      <div>
        <p style="font-size: 12px; color: var(--color-text-secondary); margin: 0 0 4px;">Pedido {DEMO_ORDER.orderId}</p>
        <h1 style="font-size: 20px; font-weight: 500; color: var(--color-text-primary); margin: 0;">
          {DEMO_ORDER.category}
        </h1>
      </div>
      <span style="font-size: 12px; font-weight: 700; color: var(--color-brand-dark); background: var(--color-brand-soft); padding: 4px 10px; border-radius: var(--border-radius-md); white-space: nowrap;">
        {STAGES[DEMO_ORDER.status].label}
      </span>
    </div>

    <div style="margin-bottom: 2rem;">
      {STAGES.map((stage, i) => {
        const isDone = i < DEMO_ORDER.status;
        const isCurrent = i === DEMO_ORDER.status;
        const isLast = i === STAGES.length - 1;
        return (
          <div style="display: flex; gap: 1rem;">
            <div style="display: flex; flex-direction: column; align-items: center;">
              <div style={`width: 32px; height: 32px; border-radius: 50%; background: ${isDone || isCurrent ? "var(--color-brand-primary)" : "var(--color-background-secondary)"}; border: ${isCurrent ? "2px solid var(--color-brand-primary)" : "none"}; display: flex; align-items: center; justify-content: center; font-size: 14px; flex-shrink: 0;`}>
                {isDone ? <span style="color: white;">✓</span> : stage.icon}
              </div>
              {!isLast && (
                <div style={`width: 2px; flex: 1; min-height: 32px; background: ${isDone ? "var(--color-brand-primary)" : "var(--color-border-tertiary)"};`}></div>
              )}
            </div>
            <div style={`padding-bottom: ${isLast ? "0" : "1.5rem"}; padding-top: 4px;`}>
              <p style={`font-size: 14px; font-weight: 500; margin: 0 0 2px; color: ${isDone || isCurrent ? "var(--color-text-primary)" : "var(--color-text-secondary)"};`}>
                {stage.label}
              </p>
              <p style="font-size: 13px; color: var(--color-text-secondary); margin: 0;">
                {stage.desc}
              </p>
              {isCurrent && stage.id === 2 && (
                <div style="margin-top: 10px; background: var(--color-background-secondary); border-radius: var(--border-radius-md); padding: 10px 12px;">
                  <p style="font-size: 12px; color: var(--color-text-secondary); margin: 0;">
                    📸 Boceto aprobado el 12 de junio · Impresión empieza en breve
                  </p>
                </div>
              )}
            </div>
          </div>
        );
      })}
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 1.5rem;">
      {[DEMO_ORDER.designer, DEMO_ORDER.printer].map((person) => (
        <div style="background: var(--color-background-primary); border: 0.5px solid var(--color-border-tertiary); border-radius: var(--border-radius-lg); padding: 1rem;">
          <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 4px;">
            <div style="width: 32px; height: 32px; border-radius: 50%; background: var(--color-brand-soft); display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; color: var(--color-brand-dark);">
              {person.name.split(" ").map((n) => n[0]).join("")}
            </div>
            <div>
              <p style="font-size: 13px; font-weight: 500; color: var(--color-text-primary); margin: 0;">
                {person.name}
              </p>
              <p style="font-size: 11px; color: var(--color-text-secondary); margin: 0;">
                {person.role}
              </p>
            </div>
          </div>
          {person.location && (
            <p style="font-size: 11px; color: var(--color-text-secondary); margin: 6px 0 0;">
              📍 {person.location}
            </p>
          )}
        </div>
      ))}
    </div>

    <div style="background: var(--color-background-secondary); border-radius: var(--border-radius-lg); padding: 1rem 1.25rem;">
      <p style="font-size: 13px; color: var(--color-text-secondary); margin: 0;">
        💬 ¿Dudas sobre tu pedido? Puedes escribir directamente al diseñador o impresor desde el chat del pedido una vez tengas cuenta creada.
      </p>
    </div>
  </main>

  <script>
    const searchScreen = document.querySelector("[data-search-screen]");
    const resultScreen = document.querySelector("[data-result-screen]");
    const searchButton = document.querySelector("[data-search-order]");
    const resetButton = document.querySelector("[data-reset-search]");

    searchButton?.addEventListener("click", () => {
      if (!searchScreen || !resultScreen) return;
      searchScreen.hidden = true;
      resultScreen.hidden = false;
      window.scrollTo(0, 0);
    });

    resetButton?.addEventListener("click", () => {
      if (!searchScreen || !resultScreen) return;
      resultScreen.hidden = true;
      searchScreen.hidden = false;
      window.scrollTo(0, 0);
    });
  </script>
</BaseLayout>
